digraph SkillTree {
    rankdir = "LR";
    graph [fontname="Helvetica,Arial,sans-serif"];
    node  [shape=box, style="rounded,filled", fontname="Helvetica,Arial,sans-serif", fontsize=11, margin="0.18,0.08", penwidth=1.5];
    "__project__" [label="MIR Formality Bug Machine", style="rounded,filled", peripheries=2, fillcolor="#222222", fontcolor="white"];
    "__cluster_Borrow checker__" [label="Borrow checker", style="rounded,filled", peripheries=2, fillcolor="#666666", fontcolor="white"];
    "__cluster_Fiddly, annoying details__" [label="Fiddly, annoying details", style="rounded,filled", peripheries=2, fillcolor="#666666", fontcolor="white"];
    "__cluster_Yakshaves__" [label="Yakshaves", style="rounded,filled", peripheries=2, fillcolor="#666666", fontcolor="white"];
    "__cluster_Rust language features__" [label="Rust language features", style="rounded,filled", peripheries=2, fillcolor="#666666", fontcolor="white"];
    "__cluster_Whatever dude__" [label="Whatever dude", style="rounded,filled", peripheries=2, fillcolor="#666666", fontcolor="white"];
    "__cluster_uncategorized__" [label="Uncategorized", style="rounded,filled", peripheries=2, fillcolor="#666666", fontcolor="white"];
    "rust-lang/a-mir-formality#209" [label="#209: Extend type/borrow-check to\nguarantee values are returned\nOPEN · Sandijigs", fillcolor="#a05ad9", fontcolor="white", color="#8048ae", URL="https://github.com/rust-lang/a-mir-formality/issues/209", tooltip="Functions can return without initializing their return place, which should be a type/borrow check error.\n\nCurrently the check for return place initialization was removed to enable the pending_outlives refactoring (threading outlives constraints as parameters instead of mutating TypeckEnv).…"];
    "rust-lang/a-mir-formality#211" [label="#211: Support 2-phase borrows\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/211", tooltip="The borrowck implementation will also need to support 2-phase borrows eventually. \n\nIn the mean time, we can already add failing test cases that would pass with the appropriate support."];
    "rust-lang/a-mir-formality#217" [label="#217: Verify self type implements trait\nin ``prove_alias_wf``\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/217", tooltip="I don't have concrete idea on how to do that yet, feel free to add more description."];
    "rust-lang/a-mir-formality#218" [label="#218: Decide what to do when there is no\n``next_block`` for ``Terminator::Call``\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/218", tooltip="In minirust, if this is value None, then UB will be raised when the function returns. I personally think we can make just make this value not an ``Option``, so our MIR that passed parsing is always valid."];
    "rust-lang/a-mir-formality#219" [label="#219: Figure out upcases with arc or\nspecial-case for…\nOPEN", fillcolor="#d9b04a", fontcolor="black", color="#ae8d3b", URL="https://github.com/rust-lang/a-mir-formality/issues/219"];
    "rust-lang/a-mir-formality#220" [label="#220: Take variance into account when\nproving ``all_sub``\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/220"];
    "rust-lang/a-mir-formality#221" [label="#221: Support transitive universal\nregion relationship\nCLOSED · tiif", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/221", tooltip="which is also making ``declared_transitive_universal_region_relationship`` test pass."];
    "rust-lang/a-mir-formality#222" [label="#222: Handle ``RigidName::AdtId``\ncorrectly in ``is_fundamental``\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/222"];
    "rust-lang/a-mir-formality#223" [label="#223: Prove there is no `TypeOfConst`\nbound for a different type when proving…\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/223"];
    "rust-lang/a-mir-formality#224" [label="#224: Handle alias ty correctly in\n``loan_not_required_by_parameter``\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/224", tooltip="Per the comment…"];
    "rust-lang/a-mir-formality#226" [label="#226: Handle `ensures` in `struct\nAliasBoundDeclBoundData` correctly\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/226", tooltip="It is currently encoded as something like `<T> [T: Foo]` where `T` represents the alias."];
    "rust-lang/a-mir-formality#227" [label="#227: Check if\n`is_definitely_not_proveable` is correct\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/227", tooltip="per the comment\n\n    // Require only universal variables, so e.g. `forall<T> not (T: Foo)`.\n    // For those, we can convert universal and existential and try to prove\n    // the inverse (so try to prove `exists<T> (T: Foo)`, with a bias towards\n    // completeness. If that fails, then we know that for all `T`, `T: Foo` is false.\n    //\n    // But with existential we can do no such trick.…"];
    "rust-lang/a-mir-formality#228" [label="#228: Resolve when/where to check for WF\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/228", tooltip="In reviewing the FIXMEs in the code, we encountered a case related to when to check that 'ensures' bounds are WF. Consider this:\n\ntrait Foo {\n    type Bar: Baz<String>;\n}\n\ntrait Baz<T: Copy> { }\n\nShould it be an error? Os is the trait ok, it can just never be implemented? (perhaps a warning, which mir-formality doesn't model)\n\nSeems related to so-called \"trivial bounds\"...…"];
    "rust-lang/a-mir-formality#229" [label="#229: decide how to handle early- and\nlate-bounds here\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/229", tooltip="From the code:\n\nWe are assuming that the function definitions have no early-bound parameters here, but in Rust they do, how should we handle this? e.g., consider\n\nfn foo<'a, T>(x: &'a T) { }\n\nin Rust this yields a type like `for<'a> foo<'a, ?X>`."];
    "rust-lang/a-mir-formality#230" [label="#230: cycle detection in borrow check is\nmore precise than real Rust\nOPEN", fillcolor="#bbbbbb", fontcolor="black", color="#969696", URL="https://github.com/rust-lang/a-mir-formality/issues/230", tooltip="From the rust\n\n// Cycle detection: if we've already visited this block with the same live loans,\n// we've reached a fixpoint and can stop recursing.…"];
    "rust-lang/a-mir-formality#231" [label="#231: \"struct\" value expression is\nspecific to \"structs\"\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/231", tooltip="We handle Struct value expressions from mini-rust, but how do we create instances of enums?"];
    "rust-lang/a-mir-formality#233" [label="#233: higher-ranked where-clauses,\noutlives\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/233", tooltip="We don't have any tests for Rust features like \n\nfn foo<T>()\nwhere\n    for<'a> T: Trait<'a>\n{}\n\nwe should fix that (and fix the borrow checker to support it!)"];
    "rust-lang/a-mir-formality#234" [label="#234: outlives and type-tests\nOPEN", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/234", tooltip="We need tests for outlives and associated type projections of various kinds."];
    "rust-lang/a-mir-formality#235" [label="#235: opaque types\nOPEN · tiif", fillcolor="#d97a4a", fontcolor="black", color="#ae623b", URL="https://github.com/rust-lang/a-mir-formality/issues/235", tooltip="These are not modeled at all and they are confusing AF."];
    "rust-lang/a-mir-formality#236" [label="#236: closures -- how to model them\nOPEN", fillcolor="#a05ad9", fontcolor="white", color="#8048ae", URL="https://github.com/rust-lang/a-mir-formality/issues/236", tooltip="We need to decide how to model closures. They have a lot of fun stuff to consider:\n\n* borrow check interactions\n* outlives\n* etc"];
    "rust-lang/a-mir-formality#247" [label="#247: Cleanup: change CoreFold output\ntype to support folding reference tuples\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/247", tooltip="Follow-up cleanup from PR #246:\n\n`CoreFold` currently requires the output type to be `Self`, which prevents `apply(&(&Wcs, &Wcs))` from producing `(Wcs, Wcs)`. Changing this would let `prove_after.rs` collapse two separate `apply` calls into a single tuple destructure:\n\n// current (two calls)\n(let assumptions = c1.substitution().apply(assumptions))\n(let goal = c1.substitution().apply(goal))…"];
    "rust-lang/a-mir-formality#248" [label="#248: Cleanup: nicer pattern for Arc in\n#[term] types\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/248", tooltip="Follow-up cleanup from PR #246:\n\nPattern-matching `#[term]` enum variants with `Arc`-wrapped fields binds as `&Arc<T>`, requiring `&**var` to dereference through the Arc before Upcast can work. For example:\n\n// current: need double-deref to get &Ty from &Arc<Ty>\nTy::My(a) => sub(&a, &b)\n\n// desired: just use the variable directly\nTy::My(a) => sub(a, b)…"];
    "rust-lang/a-mir-formality#249" [label="#249: Cleanup: NLL mutable stack\nbuilding pattern\nOPEN · nikomatsakis", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/249", tooltip="Follow-up cleanup from PR #246:\n\n`nll.rs` has a clone-heavy pattern for building an immutable stack:\n\nlet stack = { let mut s = stack.clone(); s.push(this_entry.clone()); s }\n\nThis could be made more readable, possibly with a helper or a different data structure.\n\nSee: https://github.com/rust-lang/a-mir-formality/pull/246#discussion_r2889222269"];
    "rust-lang/a-mir-formality#250" [label="#250: Cleanup: impl Upcast helper for\nNLL typed place expression construction\nOPEN", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/250", tooltip="Follow-up cleanup from PR #246:\n\n`TypedPlaceExpression` struct literal construction in `nll.rs` requires explicit `Arc::new` and `.clone()` calls:\n\nroot: Arc::new(root_expr.clone()),\nty: ty.clone(),\nkind: TypedPlaceExpressionKind::Deref(Arc::new(inner_expr.clone())),…"];
    "rust-lang/a-mir-formality#251" [label="#251: Left-recursion seed selection can\nmiss valid parses\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/251", tooltip="Summary\n\nThe left-recursion fixed-point loop selects only the longest base-case parse as the seed for each iteration. When a shorter base-case parse would compose with a left-recursive variant to produce a valid complete parse, that composition is never explored.\n\nReproducing grammar\n\nE = E . then . end     // left-recursive: needs \". then . end\" after E\n  | $id .…"];
    "rust-lang/a-mir-formality#253" [label="#253: Add back limitations to more\naccurately model NLLs\nOPEN", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/253", tooltip="https://github.com/rust-lang/a-mir-formality/pull/244 expands the borrowck implementation for what we want to reach in the future: more precision, less errors, etc.…"];
    "rust-lang/a-mir-formality#254" [label="#254: Check variable initialization\nOPEN", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/254", tooltip="In today's formality, we never check if a variable is initialized before use, so the test below passed although it shouldn't.\n\ncrate Foo {\n    fn foo () -> u32 = minirust() -> x {\n        let x: u32;\n        exists {\n            bb0: {\n                statements {\n                }\n                return;\n            }\n        }\n    };\n}\n\nThe test above is equivalent to…"];
    "rust-lang/a-mir-formality#261" [label="#261: Improve contributor onboarding\ndocs in the mdbook\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/261", tooltip="As discussed in #t-types/formality on Zulip, it would be helpful to expand the a-mir-formality to make it easier for new contributors to get started. Currently the Intro page is empty and the README lists crate names that no longer match the workspace.\n\n1.…"];
    "rust-lang/a-mir-formality#264" [label="#264: Fix \"evaluted\" typo in proof rules\noutput\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/264", tooltip="The proof rules output says \"evaluted\" instead of \"evaluated\" in several places.\n\nThe source of the typo is here in `proven_set.rs`. Fix it there, then run:\n\nUPDATE_EXPECT=1 cargo test\n\nto update the expect-test snapshots automatically.\n\ncondition evaluted to false: `place_disjoint_from_place(...)`\n\nshould be:\n\ncondition evaluated to false: `place_disjoint_from_place(...)`"];
    "rust-lang/a-mir-formality#265" [label="#265: Expand test coverage for Expr\nvariants\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/265", tooltip="Tracking issue for ensuring we have both borrow-checker (`borrowck.rs`) and type-checking (`mir_typeck.rs`) test coverage for every `Expr`, `Stmt`, and `PlaceExpr` variant.\n\nCurrent coverage gaps…"];
    "rust-lang/a-mir-formality#266" [label="#266: Add test coverage for\n`ExprData::False`\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/266", tooltip="Parent tracking issue: #265\n\nThe `ExprData::False` variant has no test coverage in either `borrowck.rs` or `mir_typeck.rs`.\n\nAdd at least one test exercising the `false` literal, e.g.:\n- A borrow-check test with `if false { ... } else { ... }`\n- A type-check test using `false` as an expression\n\nSee the parent tracking issue for instructions on how to add tests and which files to edit."];
    "rust-lang/a-mir-formality#267" [label="#267: Add type-check test coverage for\n`Stmt::If`\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/267", tooltip="Parent tracking issue: #265\n\nThe `Stmt::If` variant has borrow-check coverage (e.g., `min_problem_case_3`) but no type-checking coverage in `mir_typeck.rs`.\n\nAdd a test that exercises an `if` statement in the surface language. For example, a function that branches on a condition and returns different values from each branch.…"];
    "rust-lang/a-mir-formality#268" [label="#268: Add type-check test coverage for\n`ExprData::True`\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/268", tooltip="Parent tracking issue: #265\n\nThe `ExprData::True` variant has borrow-check coverage (e.g., `min_problem_case_3`) but no type-checking coverage in `mir_typeck.rs`.\n\nAdd a test that uses the `true` literal. This could be combined with a `Stmt::If` test. See the parent tracking issue for instructions on how to add tests."];
    "rust-lang/a-mir-formality#269" [label="#269: Add type-check test coverage for\n`PlaceExprData::Parens`\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/269", tooltip="Parent tracking issue: #265\n\nThe `PlaceExprData::Parens` variant has borrow-check coverage (e.g., `problem_case_4`) but no type-checking coverage in `mir_typeck.rs`.\n\nAdd a test that uses a parenthesized place expression, e.g., `(*v).field` where the deref needs parens to parse correctly. See the parent tracking issue for instructions on how to add tests."];
    "rust-lang/a-mir-formality#270" [label="#270: Add borrow-check test coverage for\n`ExprData::Call`\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/270", tooltip="Parent tracking issue: #265\n\nThe `ExprData::Call` variant has type-checking coverage (e.g., `test_call_terminator`) but no borrow-check coverage in `borrowck.rs`.\n\nAdd borrow-check tests exercising function calls, e.g.:\n- Passing a borrowed reference to a function\n- Calling a function while a borrow is live\n- A function that takes `&mut` preventing aliased access…"];
    "rust-lang/a-mir-formality#271" [label="#271: Add borrow-check test coverage for\n`ExprData::Turbofish`\nCLOSED · glou-nes", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/271", tooltip="Parent tracking issue: #265\n\nThe `ExprData::Turbofish` variant has type-checking coverage (e.g., `test_call_generic_fn_with_turbofish`) but no borrow-check coverage in `borrowck.rs`.\n\nAdd a borrow-check test that calls a generic function with explicit type/lifetime parameters using turbofish syntax (e.g., `identity::<u32>(v)`).\n\nSee the parent tracking issue for instructions on how to add tests."];
    "rust-lang/a-mir-formality#272" [label="#272: Add borrow-check test coverage for\n`ExprData::Struct`\nCLOSED · pranavpurankar", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/272", tooltip="Parent tracking issue: #265\n\nThe `ExprData::Struct` variant has type-checking coverage (e.g., `test_struct`) but no borrow-check coverage in `borrowck.rs`.\n\nAdd borrow-check tests exercising struct construction, e.g.:\n- Constructing a struct that borrows from a local\n- Accessing a struct field while another field is borrowed\n\nSee the parent tracking issue for instructions on how to add tests."];
    "rust-lang/a-mir-formality#288" [label="#288: Convert check functions to\njudgment functions\nOPEN", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/288", tooltip="Tracking issue for converting the top-level checking code from regular Rust functions (that manually construct proof trees) into judgment functions.\n\nHow it works today\n\na-mir-formality begins today by calling `check_all_crates`.…"];
    "rust-lang/a-mir-formality#289" [label="#289: Convert `check_trait` to a\njudgment function\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/289", tooltip="Parent tracking issue: #288\n\nConvert `check_trait` from a regular Rust function to a judgment function.\n\nCurrently it: opens the trait binder, proves where-clauses are well-formed, and checks each trait item.…"];
    "rust-lang/a-mir-formality#290" [label="#290: Convert `check_trait_impl` to a\njudgment function\nCLOSED · Sandijigs", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/290", tooltip="Parent tracking issue: #288\n\nConvert `check_trait_impl` from a regular Rust function to a judgment function.\n\nCurrently it: opens the binder, proves WF + is_implemented + not_implemented, checks safety, and checks impl items.…"];
    "rust-lang/a-mir-formality#291" [label="#291: Convert `check_neg_trait_impl` to\na judgment function\nOPEN · rustbot", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/291", tooltip="Parent tracking issue: #288\n\nConvert `check_neg_trait_impl` from a regular Rust function to a judgment function.\n\nCurrently it: opens the binder, proves WF + not_implemented, and validates that negative impls are not declared unsafe.\n\nSee the parent tracking issue for context and examples.\n\nThis issue has been assigned to @JojoFlex1 via this comment."];
    "rust-lang/a-mir-formality#292" [label="#292: Convert `check_adt` to a judgment\nfunction\nOPEN", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/292", tooltip="Parent tracking issue: #288\n\nConvert `check_adt` from a regular Rust function to a judgment function.\n\nCurrently it: opens the ADT binder, proves where-clauses are well-formed, and proves each field type is well-formed.\n\nSee the parent tracking issue for context and examples."];
    "rust-lang/a-mir-formality#293" [label="#293: Convert `check_fn` /\n`check_free_fn` to judgment functions\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/293", tooltip="Parent tracking issue: #288\n\nConvert `check_free_fn` and `check_fn` from regular Rust functions to judgment functions.\n\n`check_free_fn` is a thin wrapper that calls `check_fn` with an empty env.\n\n`check_fn` currently: proves WF of where-clauses + argument types + return type, then dispatches to the borrow checker for the function body.…"];
    "rust-lang/a-mir-formality#294" [label="#294: Convert `check_coherence` to a\njudgment function\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/294", tooltip="Parent tracking issue: #288\n\nConvert `check_coherence` from a regular Rust function to a judgment function.\n\nCurrently it orchestrates:\n- `orphan_check` / `orphan_check_neg` — proves is_local\n- `overlap_check` — proves non-overlap via not_goal or inverted where-clauses\n\nThese helpers should also be converted.\n\nSee the parent tracking issue for context and examples."];
    "rust-lang/a-mir-formality#296" [label="#296: Track initialization and moves in\nthe borrow checker\nOPEN · acegikmoo", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/296", tooltip="Updates #254. Related to #209.\n\nThe borrow checker currently does not track whether variables are initialized or have been moved. This means programs that use uninitialized variables or use variables after they've been moved are accepted when they should be rejected.\n\nFor example, this should be an error but currently passes:…"];
    "rust-lang/a-mir-formality#297" [label="#297: Reject moves out of references\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/297", tooltip="You cannot move a value out from behind a reference (`&T` or `&mut T`). Currently formality allows this.\n\nIn rustc this is error E0507: \"cannot move out of `*r` which is behind a shared/mutable reference.\" This is a property of the place being behind a reference, not about active loans — it applies even if there are no other borrows.…"];
    "rust-lang/a-mir-formality#298" [label="#298: Reject moves of borrowed places\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/298", tooltip="You cannot move a place that currently has an active loan. Currently formality detects conflicts when writing to a borrowed place, but does not specifically check moves.\n\nIn rustc this is error E0505: \"cannot move out of `x` because it is borrowed.\"…"];
    "rust-lang/a-mir-formality#304" [label="#304: Investigate why struct test is\nfailing in WF check\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/304", tooltip="PR #282 left an odd error in `src/test/borrowck.rs`. See the conversation here:\n\nhttps://github.com/rust-lang/a-mir-formality/pull/282#discussion_r3019048262"];
    "rust-lang/a-mir-formality#308" [label="#308: Consolidate the test files\nCLOSED · tiif", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/308", tooltip="Currently, our test is in both ``src/test`` and ``tests``, it will be nice to have only one place for all tests."];
    "rust-lang/a-mir-formality#312" [label="#312: Well-formedness of references\ndoesn't recurse into `ty`\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/312", tooltip="The following code passes at the moment:\n\n[test]\nfn bad() {\n    test_program_ok(\n        \"[crate core {\n            trait Trait {}\n            struct A<X> where X: Trait {}\n            fn invalid<'a, X>(x: &'a A<X>) -> ()\n            where\n                X: 'a,\n            {}\n        }]\",\n    )\n    .assert_ok();\n}…"];
    "rust-lang/a-mir-formality#315" [label="#315: explicit failures in judgments\nCLOSED", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/315", tooltip="From #310, I think we should add a new form into the judgment-fn macro like `(fail \"...\", ...)`. This would create an anyhow error that fails. It would be used to document cases that are intentionally omitted and to produce better error messages (e.g., moving from a `*` is not accepted)."];
    "rust-lang/a-mir-formality#316" [label="#316: Formality accepts impls missing\nrequired trait items (E0046)\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/316", tooltip="`check_trait_impl` does not verify that all required trait items are provided by the impl. This means formality silently accepts programs that rustc rejects with E0046 (\"not all trait items implemented\").\n\nReproduction\n\nThe following program passes formality but is rejected by rustc:\n\ntrait Foo {\n    fn bar(self_: u32) -> u32;\n}\nstruct MyStruct {}\nimpl Foo for MyStruct {}…"];
    "rust-lang/a-mir-formality#318" [label="#318: Experiment: remove `Arc` wrappers\nCLOSED · System625", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/318", tooltip="Currently we have Arc-wrapper types in a number of places--\n\nhttps://github.com/rust-lang/a-mir-formality/blob/0e9b18c8bcf5cab4f9e30d132c1d7d6cf2dcc890/crates/formality-rust/src/grammar/ty.rs#L14-L19\n\nand an inner enum type\n\nhttps://github.com/rust-lang/a-mir-formality/blob/0e9b18c8bcf5cab4f9e30d132c1d7d6cf2dcc890/crates/formality-rust/src/grammar/ty.rs#L118-L130\n\n---which I hate.…"];
    "rust-lang/a-mir-formality#329" [label="#329: Model Copy trait\nCLOSED · xonx4l", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/329", tooltip="As noted in <https://github.com/rust-lang/a-mir-formality/pull/323#discussion_r3080736286>, we are starting to need to model the actual `Copy` trait in borrow check."];
    "rust-lang/a-mir-formality#334" [label="#334: Expand Test Coverage for Ambiguity\nin PlaceExpr projections\nCLOSED · pranavpurankar", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/334", tooltip="Description\n\nThe `PlaceExpr` grammar is currently ambiguous when combining dereferences and field projections. For example, the expression `*p.f` causes a parser panic because the formality core cannot distinguish between `*(p.f)` and `(*p).f` This was identified during the implementation of borrow-check coverage in PR #282.\n\nExpected Outcome…"];
    "rust-lang/a-mir-formality#350" [label="#350: Refactor test macros to use\nmethod-chaining builder pattern\nCLOSED · rustbot", fillcolor="#888888", fontcolor="black", color="#6d6d6d", URL="https://github.com/rust-lang/a-mir-formality/issues/350", tooltip="Summary\n\nRefactor the test infrastructure to use a builder-style `FormalityTest` API with method chaining, replacing the current `assert_ok!` / `assert_err!` / `assert_rustc_success!` / `assert_rustc_error!` macros.\n\nMotivation\n\nToday we have separate macros for each kind of assertion (`assert_ok!`, `assert_err!`, `assert_rustc_success!`, `assert_rustc_error!`, `assert_equivalence!`).…"];
