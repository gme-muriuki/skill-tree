---
source: src/render/mod.rs
expression: "to_dot(&g, &opts())"
---
digraph SkillTree {
    rankdir = "LR";
    "o/r#1" [label="#1: A", shape=box, style=filled, fillcolor="#dddddd", URL="https://github.com/o/r/issues/1", tooltip="State: OPEN"];
    "o/r#2" [label="#2: B", shape=box, style=filled, fillcolor="#dddddd", URL="https://github.com/o/r/issues/2", tooltip="State: OPEN"];
    "o/r#3" [label="#3: C", shape=box, style=filled, fillcolor="#dddddd", URL="https://github.com/o/r/issues/3", tooltip="State: OPEN"];
    "o/r#2" -> "o/r#1" [style=solid, tooltip="sub-issue"];
    "o/r#3" -> "o/r#1" [style=solid, tooltip="blocks"];
    "o/r#1" -> "o/r#2" [style=dashed, constraint=false, tooltip="cross-reference"];
}
